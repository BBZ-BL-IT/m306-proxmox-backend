# Proxmox Configuration
APP_PROXMOX_URL=https://proxmox.example.com:8006
APP_PROXMOX_TOKEN_ID=TOKEN_ID
APP_PROXMOX_TOKEN_SECRET=SECRET

# Authentication
APP_USERNAME_ADMIN=USER
APP_PASSWORD_ADMIN=PASS

# Server Configuration
APP_SERVER_PORT=3000
APP_CORS_ORIGIN=http://localhost:5173

# SSL Configuration
APP_SSL_VERIFY=true
